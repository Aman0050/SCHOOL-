// ============ ACADEMIC COMMAND CENTER MODELS ============

model LessonPlan {
  id          String   @id @default(uuid())
  tenantId    String
  teacherId   String
  classId     String
  subjectId   String
  title       String
  description String   @db.Text
  date        DateTime
  status      String   @default("DRAFT") // DRAFT, IN_PROGRESS, COMPLETED
  resources   String[] // Array of resource URLs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher User        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject ExamSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model ResourceLibrary {
  id          String   @id @default(uuid())
  tenantId    String
  uploaderId  String
  classId     String?
  subjectId   String?
  title       String
  description String?  @db.Text
  fileUrl     String
  fileType    String
  fileSize    Int
  createdAt   DateTime @default(now())

  uploader User         @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  class    Class?       @relation(fields: [classId], references: [id], onDelete: SetNull)
  subject  ExamSubject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model AcademicActivityFeed {
  id          String   @id @default(uuid())
  tenantId    String
  actorId     String
  actionType  String // E.g., 'HOMEWORK_ASSIGNED', 'TIMETABLE_UPDATED', 'LESSON_COMPLETED'
  entityId    String? // ID of the related homework, timetable, etc.
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)
}

model Applicant {
  id              String   @id @default(uuid())
  tenantId        String
  
  // Student Info
  firstName       String
  middleName      String?
  lastName        String
  dateOfBirth     DateTime?
  gender          String?
  bloodGroup      String?
  nationality     String?
  religion        String?
  
  // Academic Info
  grade           String   // applying class
  previousSchool  String?
  previousClass   String?
  transferStatus  String?
  applicationNumber String? @unique

  // Contact Info
  email           String?
  phone           String?
  
  // Parent Info
  fatherName      String?
  fatherMobile    String?
  fatherEmail     String?
  fatherOccupation String?
  motherName      String?
  motherMobile    String?
  motherEmail     String?
  motherOccupation String?
  guardianRelation String?
  
  // Address Info
  address         String?
  city            String?
  state           String?
  country         String?
  postalCode      String?

  // Pipeline Info
  stage           String   @default("new-registrations")
  urgency         String   @default("normal")
  status          String   @default("Pending Review")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  documents       ApplicantDocument[]
  assessments     ApplicantAssessment[]
}

model ApplicantDocument {
  id          String   @id @default(uuid())
  tenantId    String
  applicantId String
  type        String   // Birth Certificate, Photograph, etc.
  name        String
  fileUrl     String
  status      String   @default("Pending") // Pending, Verified, Rejected
  verifiedBy  String?
  remarks     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
}

model ApplicantAssessment {
  id             String   @id @default(uuid())
  tenantId       String
  applicantId    String
  assessmentType String   // Entrance Exam, Interview
  date           DateTime
  evaluator      String?
  score          Decimal? @db.Decimal(5, 2)
  remarks        String?
  decision       String?  // Selected, Rejected, Pending
  status         String   @default("Scheduled") // Scheduled, Completed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  applicant      Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
}

// ==========================================
// DATA INTEGRITY & HEALTH (PHASE 0)
// ==========================================

model DataAnomaly {
  id            String   @id @default(uuid())
  tenantId      String
  module        String   // STUDENT, PARENT, ATTENDANCE, FEE, EXAM, ACADEMIC, TIMETABLE
  severity      String   // HIGH, MEDIUM, LOW
  issueType     String   // DUPLICATE, ORPHAN, CONSTRAINT_VIOLATION, DRIFT
  description   String
  referenceId   String?  // ID of the corrupted record (e.g. userId or feeId)
  referenceTable String?
  resolution    String?  // Suggestion or manual action needed
  status        String   @default("OPEN") // OPEN, RESOLVED, IGNORED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  resolvedAt    DateTime?

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([module])
  @@index([status])
}
