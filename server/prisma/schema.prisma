datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum SystemRole {
  SUPER_ADMIN
  PLATFORM_OWNER
  SUPPORT_AGENT
  FINANCE
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
  STAFF
  ACCOUNTANT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  EXPORT
  LOGOUT
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET
  MARKS_ENTRY
  RESULT_PUBLISH
  REPORT_CARD_GENERATE
}

model Tenant {
  id             String   @id @default(uuid())
  name           String
  domain         String?  @unique
  subdomain      String   @unique
  isActive       Boolean  @default(true)
  branding       Json?
  healthScore    Float    @default(100.0)
  onboardingStep String   @default("REGISTERED")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users          User[]
  auditLogs      AuditLog[]
  schools        School[]
  subscription   Subscription?
  invoices       SaaSInvoice[]
  supportTickets SupportTicket[]
  dataAnomalies  DataAnomaly[]

  @@index([subdomain])
}

model School {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departments        Department[]
  classes            Class[]
  academicSessions   AcademicSession[]
  examSubjects       ExamSubject[]
  exams              Exam[]
  timetables         TimetablePeriod[]
  healthScore        SchoolHealthScore?
  SchoolSubscription SchoolSubscription?
}

model User {
  id            String     @id @default(uuid())
  tenantId      String
  email         String     @unique
  passwordHash  String
  firstName     String
  lastName      String
  isActive      Boolean    @default(true)
  role          SystemRole @default(STUDENT)
  loginAttempts Int        @default(0)
  lockoutUntil  DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile             Profile?
  auditLogs           AuditLog[]
  sessions            Session[]
  resetTokens         PasswordResetToken[]
  admission           Admission?                 @relation("StudentAdmission")
  parentRelations     ParentStudent[]            @relation("StudentRelation")
  studentRelations    ParentStudent[]            @relation("ParentRelation")
  documents           StudentDocument[]
  attendance          Attendance[]               @relation("UserAttendance")
  recordedAttendance  Attendance[]               @relation("RecordedByAttendance")
  feeAssignments      StudentFeeAssignment[]     @relation("StudentFeeAssignment")
  feeCollections      FeeCollection[]            @relation("StudentCollections")
  collectedFees       FeeCollection[]            @relation("CollectedByUser")
  appliedDiscounts    StudentDiscount[]          @relation("AppliedDiscounts")
  studentFines        FineRecord[]               @relation("StudentFines")
  createdFines        FineRecord[]               @relation("CreatedFines")
  ledgerEntries       FinancialLedger[]          @relation("StudentLedger")
  ledgerCreatedBy     FinancialLedger[]          @relation("LedgerCreatedBy")
  examMarks           MarksEntry[]               @relation("StudentMarks")
  marksEntered        MarksEntry[]               @relation("MarksEnteredBy")
  marksVerified       MarksEntry[]               @relation("MarksVerifiedBy")
  examResults         StudentResult[]            @relation("StudentResults")
  reportCards         ReportCard[]               @relation("StudentReportCards")
  rankings            StudentRanking[]           @relation("StudentRankings")
  examCreated         Exam[]                     @relation("ExamCreatedBy")
  homeworksGiven      Homework[]                 @relation("HomeworkGivenBy")
  homeworkSubmissions HomeworkSubmission[]       @relation("StudentHomework")
  threadsStarted      CommunicationThread[]      @relation("ThreadStartedBy")
  messagesSent        CommunicationMessage[]     @relation("MessageSender")
  notifications       Notification[]             @relation("UserNotifications")
  deviceTokens        DeviceToken[]              @relation("UserDevices")
  ticketMessages      TicketMessage[]            @relation("TicketSender")
  enrollments         Enrollment[]
  feeNotifications    FeeNotification[]          @relation("UserFeeNotifications")
  scholarships        ScholarshipAssignment[]    @relation("StudentScholarships")
  classTeacherOf      Class[]                    @relation("ClassTeacher")
  assignedClasses     TeacherClassAssignment[]
  assignedSubjects    TeacherSubjectAssignment[]
  timetables          TimetablePeriod[]          @relation("TeacherTimetable")
  riskProfile         StudentRiskProfile?
  communicationLogs   CommunicationLog[]
  mfaEnabled          Boolean                    @default(false)
  mfaSecret           String?
  backupCodes         String[]
  deviceTrusts        DeviceTrust[]
  securityEvents      SecurityEvent[]
  privacyConsents     PrivacyConsent[]
  lessonPlans         LessonPlan[]
  resourcesUploaded   ResourceLibrary[]
  academicActivities  AcademicActivityFeed[]
  preferences         Json?
  ticketAssignments   SupportTicket[]      @relation("TicketAssignee")
  ticketActivities    TicketActivity[]     @relation("TicketActivityUser")
  kbArticles          KnowledgeBaseArticle[] @relation("KnowledgeBaseAuthor")
  supportAgent        SupportAgent?

  @@index([firstName, lastName])
  @@index([role])
}

model Admission {
  id              String   @id @default(uuid())
  tenantId        String
  studentId       String   @unique
  admissionNumber String
  admissionDate   DateTime @default(now())
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student User @relation("StudentAdmission", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([admissionNumber])
  @@unique([tenantId, admissionNumber])
}

model ParentStudent {
  id           String   @id @default(uuid())
  tenantId     String
  parentId     String
  studentId    String
  relationship String
  createdAt    DateTime @default(now())

  parent  User @relation("ParentRelation", fields: [parentId], references: [id], onDelete: Cascade)
  student User @relation("StudentRelation", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@index([tenantId])
  @@index([parentId])
  @@index([studentId])
}

model StudentDocument {
  id        String   @id @default(uuid())
  tenantId  String
  studentId String
  name      String
  fileUrl   String
  fileSize  Int
  createdAt DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Session {
  id          String   @id @default(uuid())
  userId      String
  tenantId    String
  token       String   @unique
  deviceType  String?
  osName      String?
  browserName String?
  ipAddress   String?
  isValid     Boolean  @default(true)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id          String    @id @default(uuid())
  userId      String    @unique
  phoneNumber String?
  dateOfBirth DateTime?
  gender      String?
  avatarUrl   String?
  address     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneNumber])
}

model Department {
  id        String   @id @default(uuid())
  tenantId  String
  schoolId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  courses Course[]
}

model Course {
  id           String @id @default(uuid())
  tenantId     String
  departmentId String
  name         String
  code         String
  credits      Int    @default(3)

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  classes    Class[]
}

model Class {
  id             String  @id @default(uuid())
  tenantId       String
  schoolId       String
  courseId       String
  name           String
  section        String?
  academicYear   String
  classTeacherId String?

  classTeacher       User?                      @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  school             School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  course             Course                     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments        Enrollment[]
  attendance         Attendance[]
  feeStructures      FeeStructure[]
  exams              Exam[]
  subjectMappings    ExamSubjectMapping[]
  homeworks          Homework[]
  teacherAssignments TeacherClassAssignment[]
  subjectAssignments TeacherSubjectAssignment[]
  timetables         TimetablePeriod[]
  lessonPlans        LessonPlan[]
  resources          ResourceLibrary[]
}

model Enrollment {
  id        String @id @default(uuid())
  tenantId  String
  classId   String
  studentId String
  status    String

  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentId])
}

model AuditLog {
  id        String      @id @default(uuid())
  tenantId  String
  userId    String?
  action    AuditAction
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Attendance {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String
  classId      String?
  date         DateTime
  status       String
  remarks      String?
  mode         String   @default("MANUAL")
  recordedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User   @relation("UserAttendance", fields: [userId], references: [id], onDelete: Cascade)
  recordedBy User?  @relation("RecordedByAttendance", fields: [recordedById], references: [id], onDelete: SetNull)
  class      Class? @relation(fields: [classId], references: [id], onDelete: SetNull)

  @@unique([userId, date, classId])
  @@index([tenantId])
  @@index([userId])
  @@index([date])
}

// ============ FEE MANAGEMENT ENUMS ============

enum FeeStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  WAIVED
}

enum PaymentMethod {
  CASH
  UPI
  RAZORPAY
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  CHEQUE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum FineType {
  LATE_PAYMENT
  LIBRARY
  DAMAGE
  DISCIPLINE
  OTHER
}

enum TransactionType {
  CREDIT
  DEBIT
  REFUND
  ADJUSTMENT
}

enum IntervalType {
  ONE_TIME
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUALLY
  CUSTOM
}

// ============ FEE MANAGEMENT MODELS ============

model FeeInstallmentPlan {
  id                String       @id @default(uuid())
  tenantId          String
  name              String
  intervalType      IntervalType
  totalInstallments Int
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  assignments StudentFeeAssignment[]
}

model FeeInstallment {
  id                String    @id @default(uuid())
  tenantId          String
  assignmentId      String
  installmentPlanId String?
  name              String
  amount            Decimal   @db.Decimal(12, 2)
  dueDate           DateTime
  isPaid            Boolean   @default(false)
  paidAmount        Decimal   @default(0) @db.Decimal(12, 2)
  status            FeeStatus @default(PENDING)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  assignment StudentFeeAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

model FeeCategory {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  feeStructureItems FeeStructureItem[]
}

model FeeStructure {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  classId      String?
  academicYear String
  totalAmount  Decimal  @db.Decimal(12, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  class       Class?                 @relation(fields: [classId], references: [id], onDelete: SetNull)
  items       FeeStructureItem[]
  assignments StudentFeeAssignment[]
}

model FeeStructureItem {
  id             String    @id @default(uuid())
  tenantId       String
  feeStructureId String
  feeCategoryId  String
  amount         Decimal   @db.Decimal(12, 2)
  dueDate        DateTime?
  isOptional     Boolean   @default(false)
  createdAt      DateTime  @default(now())

  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  feeCategory  FeeCategory  @relation(fields: [feeCategoryId], references: [id], onDelete: Cascade)
}

model StudentFeeAssignment {
  id             String    @id @default(uuid())
  tenantId       String
  studentId      String
  feeStructureId String
  academicYear   String
  totalAmount    Decimal   @db.Decimal(12, 2)
  discountAmount Decimal   @default(0) @db.Decimal(12, 2)
  fineAmount     Decimal   @default(0) @db.Decimal(12, 2)
  paidAmount     Decimal   @default(0) @db.Decimal(12, 2)
  dueAmount      Decimal   @db.Decimal(12, 2)
  status         FeeStatus @default(PENDING)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  installmentPlanId String?

  student         User                @relation("StudentFeeAssignment", fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure    FeeStructure        @relation(fields: [feeStructureId], references: [id])
  collections     FeeCollection[]
  discounts       StudentDiscount[]
  fines           FineRecord[]
  installmentPlan FeeInstallmentPlan? @relation(fields: [installmentPlanId], references: [id])
  installments    FeeInstallment[]

  @@unique([studentId, feeStructureId, academicYear])
  @@index([tenantId])
  @@index([studentId])
}

model FeeDiscount {
  id            String       @id @default(uuid())
  tenantId      String
  name          String
  description   String?
  type          DiscountType
  value         Decimal      @db.Decimal(10, 2)
  isScholarship Boolean      @default(false)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  studentDiscounts StudentDiscount[]
}

model StudentDiscount {
  id            String   @id @default(uuid())
  tenantId      String
  studentId     String
  assignmentId  String
  discountId    String
  appliedAmount Decimal  @db.Decimal(12, 2)
  appliedBy     String
  remarks       String?
  createdAt     DateTime @default(now())

  assignment    StudentFeeAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  discount      FeeDiscount          @relation(fields: [discountId], references: [id])
  appliedByUser User                 @relation("AppliedDiscounts", fields: [appliedBy], references: [id])
}

model FeeCollection {
  id            String    @id @default(uuid())
  tenantId      String
  assignmentId  String
  studentId     String
  receiptNumber String
  totalAmount   Decimal   @db.Decimal(12, 2)
  paidAmount    Decimal   @db.Decimal(12, 2)
  status        FeeStatus @default(PENDING)
  collectedBy   String
  remarks       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignment      StudentFeeAssignment @relation(fields: [assignmentId], references: [id])
  student         User                 @relation("StudentCollections", fields: [studentId], references: [id])
  collectedByUser User                 @relation("CollectedByUser", fields: [collectedBy], references: [id])
  payments        PaymentInstallment[]

  @@unique([tenantId, receiptNumber])
  @@index([tenantId])
  @@index([studentId])
  @@index([status])
}

model PaymentInstallment {
  id               String        @id @default(uuid())
  tenantId         String
  collectionId     String
  amount           Decimal       @db.Decimal(12, 2)
  method           PaymentMethod
  status           PaymentStatus @default(PENDING)
  transactionId    String?
  gatewayOrderId   String?
  gatewayPaymentId String?
  gatewaySignature String?
  remarks          String?
  paidAt           DateTime      @default(now())
  createdAt        DateTime      @default(now())

  collection FeeCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

model FineRecord {
  id           String    @id @default(uuid())
  tenantId     String
  studentId    String
  assignmentId String?
  type         FineType
  amount       Decimal   @db.Decimal(12, 2)
  reason       String
  isPaid       Boolean   @default(false)
  paidAt       DateTime?
  waivedBy     String?
  waivedAt     DateTime?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  student       User                  @relation("StudentFines", fields: [studentId], references: [id])
  assignment    StudentFeeAssignment? @relation(fields: [assignmentId], references: [id])
  createdByUser User                  @relation("CreatedFines", fields: [createdBy], references: [id])
}

model FinancialLedger {
  id            String          @id @default(uuid())
  tenantId      String
  studentId     String
  referenceType String
  referenceId   String
  description   String
  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  balance       Decimal         @db.Decimal(12, 2)
  createdBy     String
  createdAt     DateTime        @default(now())

  student       User @relation("StudentLedger", fields: [studentId], references: [id])
  createdByUser User @relation("LedgerCreatedBy", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([studentId])
  @@index([tenantId, studentId])
}

model FeeReceiptCounter {
  id         String   @id @default(uuid())
  tenantId   String   @unique
  prefix     String   @default("RCP")
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model LateFeeRule {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  daysFrom  Int
  daysTo    Int?
  amount    Decimal  @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Scholarship {
  id          String       @id @default(uuid())
  tenantId    String
  name        String
  description String?
  type        DiscountType
  value       Decimal      @db.Decimal(10, 2)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  assignedStudents ScholarshipAssignment[]
}

model ScholarshipAssignment {
  id            String   @id @default(uuid())
  tenantId      String
  studentId     String
  scholarshipId String
  academicYear  String
  status        String   @default("ACTIVE")
  assignedBy    String
  createdAt     DateTime @default(now())

  student     User        @relation("StudentScholarships", fields: [studentId], references: [id])
  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
}

model FeeNotification {
  id           String    @id @default(uuid())
  tenantId     String
  userId       String
  assignmentId String?
  type         String
  channel      String
  status       String    @default("PENDING")
  sentAt       DateTime?
  createdAt    DateTime  @default(now())

  user User @relation("UserFeeNotifications", fields: [userId], references: [id])
}

// ============ EXAMINATION MANAGEMENT ENUMS ============

enum ExamType {
  UNIT_TEST
  MONTHLY_TEST
  QUARTERLY
  HALF_YEARLY
  ANNUAL
  PRE_BOARD
  BOARD
  PRACTICAL
  VIVA
  INTERNAL
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
  PUBLISHED
}

enum ExamSubjectType {
  THEORY
  PRACTICAL
  BOTH
  VIVA
}

enum BoardType {
  CBSE
  ICSE
  STATE_BOARD
  INTERNATIONAL
  CUSTOM
}

enum GradeSystemType {
  PERCENTAGE
  GRADE
  GPA
  CGPA
  CUSTOM
}

enum MarksEntryStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  LOCKED
}

enum RankBasis {
  PERCENTAGE
  TOTAL_MARKS
  GRADE_POINTS
}

// ============ EXAMINATION MANAGEMENT MODELS ============

model AcademicSession {
  id        String   @id @default(uuid())
  tenantId  String
  schoolId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms  ExamTerm[]
  exams  Exam[]
}

model ExamTerm {
  id               String   @id @default(uuid())
  tenantId         String
  sessionId        String
  name             String
  startDate        DateTime
  endDate          DateTime
  weightagePercent Decimal  @default(0) @db.Decimal(5, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  session AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exams   Exam[]
}

model ExamSubject {
  id                 String          @id @default(uuid())
  tenantId           String
  schoolId           String
  code               String
  name               String
  subjectType        ExamSubjectType @default(THEORY)
  theoryMaxMarks     Int             @default(100)
  practicalMaxMarks  Int             @default(0)
  totalMaxMarks      Int             @default(100)
  theoryPassMarks    Int             @default(33)
  practicalPassMarks Int             @default(0)
  boardType          BoardType       @default(CBSE)
  isElective         Boolean         @default(false)
  isOptional         Boolean         @default(false)
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  school             School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjectMappings    ExamSubjectMapping[]
  scheduleItems      ExamSubjectSchedule[]
  marksEntries       MarksEntry[]
  studentResults     StudentResult[]
  studentRankings    StudentRanking[]
  homeworks          Homework[]
  teacherAssignments TeacherSubjectAssignment[]
  timetables         TimetablePeriod[]
  lessonPlans        LessonPlan[]
  resources          ResourceLibrary[]
}

model ExamSubjectMapping {
  id         String   @id @default(uuid())
  tenantId   String
  classId    String
  subjectId  String
  isElective Boolean  @default(false)
  isOptional Boolean  @default(false)
  createdAt  DateTime @default(now())

  class   Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject ExamSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classId, subjectId])
}

model Exam {
  id              String          @id @default(uuid())
  tenantId        String
  schoolId        String
  sessionId       String
  termId          String?
  classId         String
  name            String
  examType        ExamType
  status          ExamStatus      @default(DRAFT)
  startDate       DateTime
  endDate         DateTime
  weightage       Decimal         @default(100) @db.Decimal(5, 2)
  passingCriteria Decimal         @default(33) @db.Decimal(5, 2)
  boardType       BoardType       @default(CBSE)
  gradeSystem     GradeSystemType @default(PERCENTAGE)
  publishedAt     DateTime?
  publishedBy     String?
  remarks         String?
  createdBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  school         School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session        AcademicSession       @relation(fields: [sessionId], references: [id])
  term           ExamTerm?             @relation(fields: [termId], references: [id])
  class          Class                 @relation(fields: [classId], references: [id])
  schedules      ExamSubjectSchedule[]
  marksEntries   MarksEntry[]
  studentResults StudentResult[]
  reportCards    ReportCard[]
  rankings       StudentRanking[]
  createdByUser  User                  @relation("ExamCreatedBy", fields: [createdBy], references: [id])
}

model ExamSubjectSchedule {
  id                String   @id @default(uuid())
  tenantId          String
  examId            String
  subjectId         String
  examDate          DateTime
  startTime         String?
  endTime           String?
  maxMarks          Int
  passingMarks      Int
  practicalMaxMarks Int      @default(0)
  createdAt         DateTime @default(now())

  exam    Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
